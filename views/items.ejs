<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1><%= locals.category %> Items</h1>
    <a href="/items/new?category=<%= locals.category %>">add new item</a>
    <div>
        <% items.forEach(item => { %>
            <div>
                <p><a href="<%= topUrl %>/<%= item.name %>"><%= item.name %></a></p>

                <% if (!locals.category) { %>
                    <p><%=item.category%></p>
                    
                <% } %>
            </div>
        <% }) %>
    </div>  
    <a href="/">go back to index</a>
</body>
</html>